# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Project-local tooling (JDK 17, Android SDK, AVDs) — see .tools/env.sh
/.tools/

# Release APKs are kept locally for sharing, not committed
.claude/releases/

# OAuth client secrets / downloaded credentials — NEVER commit
.claude/env/

# Operator scratch / handoff files (never sweep into commits)
.claude/tmp/

# Release signing — keystore + property file MUST never be committed.
# The keystore lives outside the repo (operator-owned). key.properties is
# project-local but contains the store password / key password.
/android/key.properties
*.jks
*.keystore
